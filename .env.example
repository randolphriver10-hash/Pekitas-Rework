# Supabase — provisionado vía Vercel Marketplace (vercel integration add supabase).
# Estas dos son PÚBLICAS: se exponen al navegador (prefijo NEXT_PUBLIC_). Están protegidas
# por Row Level Security (RLS) en Postgres, no por ser secretas.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# PRIVADA: solo se usa en Server Actions / Route Handlers (servidor). NUNCA debe llevar
# el prefijo NEXT_PUBLIC_ ni importarse desde un componente cliente. Bypassa RLS.
SUPABASE_SECRET_KEY=

# Connection string directa a Postgres (servidor únicamente). Se usa para ejecutar las
# migraciones SQL de supabase/migrations/ con `npm run db:migrate`.
POSTGRES_URL_NON_POOLING=

# Base URL pública del sitio (usada en metadata/SEO, mensajes de WhatsApp, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
